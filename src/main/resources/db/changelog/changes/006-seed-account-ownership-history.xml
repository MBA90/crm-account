<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Sample ownership changes for local/dev use only (context "dev"). account_id
      values reference the accounts seeded in 002-seed-accounts.xml; owner ids use
      the a0000000-... Keycloak subject convention from the same file.
    -->
    <changeSet id="006-seed-account-ownership-history" author="crm" context="dev">

        <!-- Globex Corporation: initial assignment (no previous owner) -->
        <insert tableName="account_ownership_history">
            <column name="history_id" value="e1111111-1111-1111-1111-111111111111"/>
            <column name="account_id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="to_owner_id" value="a0000000-0000-0000-0000-000000000001"/>
            <column name="reason" value="reassignment"/>
            <column name="changed_by" value="a0000000-0000-0000-0000-000000000003"/>
        </insert>

        <!-- Initech GmbH: territory redraw moved the account between reps -->
        <insert tableName="account_ownership_history">
            <column name="history_id" value="e2222222-2222-2222-2222-222222222222"/>
            <column name="account_id" value="33333333-3333-3333-3333-333333333333"/>
            <column name="from_owner_id" value="a0000000-0000-0000-0000-000000000001"/>
            <column name="to_owner_id" value="a0000000-0000-0000-0000-000000000002"/>
            <column name="reason" value="territory"/>
            <column name="changed_by" value="a0000000-0000-0000-0000-000000000003"/>
        </insert>

        <!-- Fourth account: previous rep left the company -->
        <insert tableName="account_ownership_history">
            <column name="history_id" value="e3333333-3333-3333-3333-333333333333"/>
            <column name="account_id" value="44444444-4444-4444-4444-444444444444"/>
            <column name="from_owner_id" value="a0000000-0000-0000-0000-000000000001"/>
            <column name="to_owner_id" value="a0000000-0000-0000-0000-000000000002"/>
            <column name="reason" value="departure"/>
            <column name="changed_by" value="a0000000-0000-0000-0000-000000000003"/>
        </insert>

        <rollback>
            <delete tableName="account_ownership_history">
                <where>history_id in (
                    'e1111111-1111-1111-1111-111111111111',
                    'e2222222-2222-2222-2222-222222222222',
                    'e3333333-3333-3333-3333-333333333333')</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
