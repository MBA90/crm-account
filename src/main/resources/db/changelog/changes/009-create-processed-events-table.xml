<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Idempotency guard for inbound events; event_id comes from the event itself. -->
    <changeSet id="009-create-processed-events-table" author="crm">
        <createTable tableName="processed_events">
            <column name="event_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_processed_events" nullable="false"/>
            </column>
            <column name="processed_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
