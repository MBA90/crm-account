<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Sample contacts for local/dev use only (context "dev"). account_id values
      reference the accounts seeded in 002-seed-accounts.xml.
    -->
    <changeSet id="004-seed-contacts" author="crm" context="dev">

        <!-- Globex Corporation: a primary decision maker + a technical contact -->
        <insert tableName="contacts">
            <column name="contact_id" value="c1111111-1111-1111-1111-111111111111"/>
            <column name="account_id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="first_name" value="Alice"/>
            <column name="last_name" value="Turner"/>
            <column name="email" value="alice.turner@globex.example.com"/>
            <column name="phone" value="+12125550100"/>
            <column name="mobile" value="+12125550101"/>
            <column name="job_title" value="Chief Operating Officer"/>
            <column name="department" value="Executive"/>
            <column name="is_primary" valueBoolean="true"/>
            <column name="decision_role" value="decision_maker"/>
            <column name="status" value="Active"/>
        </insert>

        <insert tableName="contacts">
            <column name="contact_id" value="c2222222-2222-2222-2222-222222222222"/>
            <column name="account_id" value="11111111-1111-1111-1111-111111111111"/>
            <column name="first_name" value="Bob"/>
            <column name="last_name" value="Ng"/>
            <column name="email" value="bob.ng@globex.example.com"/>
            <column name="mobile" value="+12125550102"/>
            <column name="job_title" value="Head of IT"/>
            <column name="department" value="Technology"/>
            <column name="is_primary" valueBoolean="false"/>
            <column name="decision_role" value="technical"/>
            <column name="status" value="Active"/>
        </insert>

        <!-- Initech GmbH: a billing contact -->
        <insert tableName="contacts">
            <column name="contact_id" value="c3333333-3333-3333-3333-333333333333"/>
            <column name="account_id" value="33333333-3333-3333-3333-333333333333"/>
            <column name="first_name" value="Clara"/>
            <column name="last_name" value="Baumann"/>
            <column name="email" value="clara.baumann@initech.example.com"/>
            <column name="phone" value="+493012345678"/>
            <column name="job_title" value="Finance Manager"/>
            <column name="department" value="Finance"/>
            <column name="is_primary" valueBoolean="true"/>
            <column name="decision_role" value="billing"/>
            <column name="status" value="Active"/>
        </insert>

        <!-- Same person as a contact at a second account (email NOT globally unique) -->
        <insert tableName="contacts">
            <column name="contact_id" value="c4444444-4444-4444-4444-444444444444"/>
            <column name="account_id" value="44444444-4444-4444-4444-444444444444"/>
            <column name="first_name" value="Clara"/>
            <column name="last_name" value="Baumann"/>
            <column name="email" value="clara.baumann@initech.example.com"/>
            <column name="mobile" value="+447700900123"/>
            <column name="job_title" value="Advisory Board Member"/>
            <column name="department" value="Advisory"/>
            <column name="is_primary" valueBoolean="false"/>
            <column name="decision_role" value="influencer"/>
            <column name="status" value="Active"/>
        </insert>

        <rollback>
            <delete tableName="contacts">
                <where>contact_id in (
                    'c1111111-1111-1111-1111-111111111111',
                    'c2222222-2222-2222-2222-222222222222',
                    'c3333333-3333-3333-3333-333333333333',
                    'c4444444-4444-4444-4444-444444444444')</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
