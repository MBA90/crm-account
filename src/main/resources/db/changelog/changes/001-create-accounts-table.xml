<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-accounts-table" author="crm">
        <createTable tableName="accounts">
            <column name="account_id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_accounts" nullable="false"/>
            </column>
            <column name="legal_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="trade_name" type="VARCHAR(255)"/>
            <column name="registration_no" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="tax_id" type="VARCHAR(100)"/>
            <column name="industry" type="VARCHAR(255)"/>
            <column name="employee_band" type="VARCHAR(20)"/>
            <column name="country" type="VARCHAR(100)"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="website" type="VARCHAR(255)"/>
            <column name="parent_account_id" type="UUID"/>
            <column name="account_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="source" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="deactivated_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="erased_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addUniqueConstraint
                tableName="accounts"
                columnNames="registration_no, country"
                constraintName="uq_accounts_registration_no_country"/>

        <addForeignKeyConstraint
                baseTableName="accounts"
                baseColumnNames="parent_account_id"
                referencedTableName="accounts"
                referencedColumnNames="account_id"
                constraintName="fk_accounts_parent_account"
                onDelete="SET NULL"/>

        <createIndex tableName="accounts" indexName="idx_accounts_parent_account_id">
            <column name="parent_account_id"/>
        </createIndex>

        <createIndex tableName="accounts" indexName="idx_accounts_owner_id_status">
            <column name="owner_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
